class Voter:
    def __init__(self, voter_id, name, age, password):
        self.voter_id = voter_id
        self.name = name
        self.age = age
        self.password = password
        self.has_voted = False

class Candidate:
    def __init__(self, name):
        self.name = name
        self.votes = 0

class Election:
    def __init__(self):
        self.voters = []
        self.candidates = [Candidate("Rahul"), Candidate("Priya"), Candidate("Aman"), Candidate("NOTA")]

    def register_voter(self):
        print("\n--- Register Voter ---")
        vid = input("Voter ID: ").strip()
        if any(v.voter_id == vid for v in self.voters):
            print("Voter ID already exists.")
            return
        name = input("Name: ").strip()
        if not name:
            print("Name cannot be empty.")
            return
        try:
            age = int(input("Age: "))
        except ValueError:
            print("Invalid age.")
            return
        if age < 18:
            print("Only 18+ can vote.")
            return
        pwd = input("Password: ").strip()
        self.voters.append(Voter(vid, name, age, pwd))
        print("Registration successful.")

    def login(self):
        vid = input("Voter ID: ")
        pwd = input("Password: ")
        for v in self.voters:
            if v.voter_id == vid and v.password == pwd:
                return v
        print("Invalid credentials.")
        return None

    def cast_vote(self, voter):
        if voter.has_voted:
            print("You have already voted.")
            return
        print("\nCandidates:")
        for i,c in enumerate(self.candidates,1):
            print(f"{i}. {c.name}")
        try:
            ch=int(input("Choose candidate: "))
        except ValueError:
            print("Invalid choice.")
            return
        if 1<=ch<=len(self.candidates):
            self.candidates[ch-1].votes += 1
            voter.has_voted=True
            print("Vote cast successfully.")
        else:
            print("Invalid choice.")

    def result(self):
        print("\n=== Election Result ===")
        total=sum(c.votes for c in self.candidates)
        winner=max(self.candidates,key=lambda c:c.votes)
        for c in self.candidates:
            print(f"{c.name}: {c.votes}")
        print("Total Votes:",total)
        if total:
            top=winner.votes
            ties=[c.name for c in self.candidates if c.votes==top]
            if len(ties)==1:
                print("Winner:",winner.name)
            else:
                print("Tie between:",", ".join(ties))
        else:
            print("No votes cast.")

def main():
    e=Election()
    while True:
        print("\n==== ONLINE VOTING SYSTEM ====")
        print("1. Register Voter")
        print("2. Login & Vote")
        print("3. Show Result")
        print("4. Exit")
        ch=input("Enter choice: ")
        if ch=="1":
            e.register_voter()
        elif ch=="2":
            v=e.login()
            if v:
                e.cast_vote(v)
        elif ch=="3":
            e.result()
        elif ch=="4":
            print("Thank you!")
            break
        else:
            print("Invalid option.")

if __name__=="__main__":
    main()
